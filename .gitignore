# ── Terraform ─────────────────────────────────────────────────────────────────
# Local state — never commit
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Terraform plan files — contain sensitive data
*.tfplan
tfplan

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform lock file — commit this if using consistent provider versions
# .terraform.lock.hcl

# Terraform working directories
**/.terraform/
**/.terraform.lock.hcl

# Generated Terraform — committed intentionally by the agent
# Do NOT ignore terraform/generated/ — that's the agent output
# terraform/generated/

# ── AWS ───────────────────────────────────────────────────────────────────────
# Never commit credentials
.aws/
*.pem
*.key
credentials

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.secret
secrets.json
secrets.yaml
secrets.yml

